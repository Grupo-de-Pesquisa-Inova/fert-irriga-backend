# Segredos da stack de produção (docker-compose.prod.yml).
# Copie para .env e preencha com valores fortes. NUNCA versione o .env.

# ── PostgreSQL ────────────────────────────────────────────────
POSTGRES_USER=fertirriga
POSTGRES_PASSWORD=TROQUE_POR_UMA_SENHA_FORTE
POSTGRES_DB=fertirriga

# ── MQTT (mesmas credenciais usadas no broker, no backend e no ESP32) ──
MQTT_USERNAME=esp-fertirriga
MQTT_PASSWORD=TROQUE_POR_UMA_SENHA_FORTE

# ── CORS — domínio público do frontend (sem localhost, sem '*') ──
CORS_ORIGIN=https://app.seu-dominio.com
