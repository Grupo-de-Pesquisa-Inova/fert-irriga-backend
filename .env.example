# Ambiente: "development" (padrão) ou "production".
# Em "production", o backend recusa credenciais/padrões inseguros na inicialização.
APP_ENV=development

# Porta HTTP do backend
PORT=8080

# String de conexão PostgreSQL.
# Em produção: use credenciais fortes e sslmode=require (ou superior).
DATABASE_URL=postgres://fertirriga:fertirriga@localhost:5432/fertirriga?sslmode=disable

# Broker MQTT.
# Em produção: use mqtts:// (TLS) e defina usuário/senha abaixo.
MQTT_BROKER_URL=mqtt://localhost:1883
MQTT_CLIENT_ID=fertirriga-backend
MQTT_USERNAME=
MQTT_PASSWORD=

# Origens permitidas para CORS (separadas por vírgula).
# Em produção: informe o domínio real do frontend, nunca localhost ou "*".
CORS_ORIGIN=http://localhost:5173
